<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SimonGame">

        <!--
        activity della Schermata 1, il gioco con la matrice colorata.
        L'applicazione parte lanciando GameActivity.
        -->
        <activity
            android:name=".GameActivity"
            android:exported="true"
            android:theme="@style/Theme.SimonGame">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
        activity della Schermata 2, la lista delle partite giocate.
        GameHistoryActivity viene chiamata via intent alla pressione del tasto "Fine Partita" (dalla Schermata 1).
         -->
        <activity
            android:name=".GameHistoryActivity"
            android:exported="true"
            android:theme="@style/Theme.SimonGame" />
    </application>

</manifest>